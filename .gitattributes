# Default: commit all text files with LF line endings
* text=auto eol=lf

# Keep CRLF for Windows-specific scripts (avoid issues in Notepad/batch)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Force LF for shell/build scripts (safest in WSL/containers/CI)
*.sh text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Common binary files — disable line-ending conversion and diff
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Lock files should stay LF to avoid cross-platform diff noise
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf

