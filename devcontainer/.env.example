# ============================================
# Environment Variables for Docker Compose
# ============================================
# Copy this file to .env before starting:
#   cp .env.example .env
#
# Then create a Grafana token and paste it below.
# ============================================

# Grafana Service Account Token
# How to create one:
#   1. Start containers: docker compose -f devcontainer/compose.influxdb.yaml up -d
#   2. Open Grafana: http://localhost:3001 (login: admin / admin)
#   3. Go to: Administration -> Service Accounts -> Add Service Account
#   4. Set role to Admin, then click "Add Token"
#   5. Copy the token (starts with "glsa_") and paste below
GRAFANA_TOKEN=<paste-your-token-here>
